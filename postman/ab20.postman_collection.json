            {
              "name": "Stress Test - Parallel Create Orders",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{orderBaseUrl}}/health",
                  "host": [
                    "{{orderBaseUrl}}"
                  ],
                  "path": [
                    "health"
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const baseUrl = pm.collectionVariables.get('orderBaseUrl') || pm.variables.get('orderBaseUrl') || 'http://localhost:3000';",
                      "const productId = Number(pm.collectionVariables.get('stressProductId') || 1);",
                      "const userId = Number(pm.collectionVariables.get('stressUserId') || 1);",
                      "const quantityPerOrder = Number(pm.collectionVariables.get('stressQuantityPerOrder') || 1);",
                      "const parallelRequests = Number(pm.collectionVariables.get('stressParallelRequests') || 20);",
                      "",
                      "pm.test('Stress test configuration is valid', function () {",
                      "  pm.expect(productId).to.be.a('number').and.to.be.above(0);",
                      "  pm.expect(userId).to.be.a('number').and.to.be.above(0);",
                      "  pm.expect(quantityPerOrder).to.be.a('number').and.to.be.above(0);",
                      "  pm.expect(parallelRequests).to.be.a('number').and.to.be.above(0);",
                      "});",
                      "",
                      "function sendOrderRequest(index) {",
                      "  return new Promise(function (resolve) {",
                      "    pm.sendRequest({",
                      "      url: baseUrl + '/orders',",
                      "      method: 'POST',",
                      "      header: { 'Content-Type': 'application/json' },",
                      "      body: {",
                      "        mode: 'raw',",
                      "        raw: JSON.stringify({",
                      "          user: { id: userId },",
                      "          notes: 'parallel-test-' + index,",
                      "          lines: [{ productId: productId, quantity: quantityPerOrder }]",
                      "        })",
                      "      }",
                      "    }, function (err, res) {",
                      "      resolve({ err: err, status: res ? res.code : 0 });",
                      "    });",
                      "  });",
                      "}",
                      "",
                      "const orderCalls = [];",
                      "for (let i = 0; i < parallelRequests; i += 1) {",
                      "  orderCalls.push(sendOrderRequest(i + 1));",
                      "}",
                      "",
                      "Promise.all(orderCalls).then(function (results) {",
                      "  const successCount = results.filter(function (result) { return result.status === 201; }).length;",
                      "  const conflictCount = results.filter(function (result) { return result.status === 409; }).length;",
                      "  const errorCount = results.filter(function (result) { return Boolean(result.err); }).length;",
                      "",
                      "  pm.collectionVariables.set('stressSuccessCount', String(successCount));",
                      "  pm.collectionVariables.set('stressConflictCount', String(conflictCount));",
                      "  pm.collectionVariables.set('stressErrorCount', String(errorCount));",
                      "",
                      "  pm.test('Parallel calls completed without transport errors', function () {",
                      "    pm.expect(errorCount).to.eql(0);",
                      "  });",
                      "",
                      "  pm.sendRequest(baseUrl + '/products/' + productId, function (productErr, productRes) {",
                      "    pm.test('Can fetch product after stress run', function () {",
                      "      pm.expect(productErr).to.eql(null);",
                      "      pm.expect(productRes).to.have.property('code', 200);",
                      "    });",
                      "",
                      "    pm.test('Final inventory is not negative', function () {",
                      "      const productJson = productRes.json();",
                      "      pm.expect(productJson).to.have.property('inventoryCount');",
                      "      pm.expect(productJson.inventoryCount).to.be.at.least(0);",
                      "    });",
                      "",
                      "    pm.test('At least one order call was processed', function () {",
                      "      pm.expect(successCount + conflictCount).to.equal(parallelRequests);",
                      "    });",
                      "  });",
                      "});"
                    ]
                  }
                }
              ]
            },
